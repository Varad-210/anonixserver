# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── API Base URL (for file uploads) ───────────────────────────────────────────
# Your backend URL (used to generate full file URLs for cross-origin access)
# Example: https://anonixserver.onrender.com (no trailing slash)
API_BASE_URL=https://anonixserver.onrender.com

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your cluster URL)
MONGODB_URI=mongodb+srv://varad:<db-password>@cluster.pweh0rb.mongodb.net/?appName=Cluster

# ── CORS ──────────────────────────────────────────────────────────────────────
# DEPRECATED: CORS now uses pattern matching (*.netlify.app + localhost)
# No need to set CLIENT_URL anymore - all Netlify preview URLs work automatically

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Use long, random strings (e.g. openssl rand -hex 64)
JWT_SECRET=ZpaScuB6qDfTb6bn76dxoNufP9NYAOmwTJIwOxeY2UW
ADMIN_JWT_SECRET=replace_with_another_64_char_random_hex

# ── Cloudinary (optional — only needed for image uploads) ────────────────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── Redis (optional — only needed for horizontal scaling) ────────────────────
# REDIS_URL=redis://localhost:6379
